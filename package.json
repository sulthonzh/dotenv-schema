{
  "name": "@sulthonzh/dotenv-schema",
  "version": "1.0.0",
  "description": "Type-safe .env schema definition tool that generates validation code and .env.example files",
  "main": "dist/index.js",
  "bin": {
    "dotenv-schema": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:test": "tsc --project tsconfig.test.json",
    "test": "npm run build:test && node --test dist-tests/**/*.test.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "dotenv",
    "env",
    "schema",
    "validation",
    "type-safe",
    "cli"
  ],
  "author": "sulthonzh",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "enquirer": "^2.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/dotenv-schema.git"
  }
}